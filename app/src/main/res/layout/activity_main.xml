<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FF1F1F1F">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WireGuard VPN"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnScanQR"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="📷 Scan QR Code"/>

        <Button
            android:id="@+id/btnImport"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="📁 Import .conf"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <Spinner
        android:id="@+id/spinnerConfigs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etConfig"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:hint="Config ปัจจุบัน..."
        android:inputType="textMultiLine"
        android:gravity="top|start"
        android:background="#FFFFFFFF"
        android:textColor="#000000"
        android:padding="12dp"/>

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔗 เชื่อมต่อ"
        android:backgroundTint="#8B5CF6"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnDisconnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⛔ ตัดการเชื่อมต่อ"
        android:backgroundTint="#EF4444"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="สถานะ: Disconnected"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvTraffic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Traffic: rx: 0 B | tx: 0 B"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:layout_marginTop="8dp"/>

</LinearLayout>